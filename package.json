    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "test": "bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "events-typed": "^2.0.0"
  }
}
