{
  "name": "bun-kasa",
  "version": "0.1.0",
  "description": "TypeScript port of python-kasa for controlling TP-Link Kasa/Tapo smart home devices, built for Bun.",
  "type": "module",
  "module": "src/index.ts",
  "types": "dist/index.d.ts",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
